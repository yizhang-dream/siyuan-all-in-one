{
  "name": "siyuan-all-in-one",
  "version": "1.0.0",
  "type": "module",
  "description": "Concept-centered SM-2 flashcards with AI generation, OpenNotebook integration, and bidirectional concept mindmaps for SiYuan",
  "author": "zyz",
  "license": "MIT",
  "homepage": "https://github.com/yizhang-dream/siyuan-all-in-one#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yizhang-dream/siyuan-all-in-one.git"
  },
  "bugs": {
    "url": "https://github.com/yizhang-dream/siyuan-all-in-one/issues"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production vite build",
    "dev": "cross-env NODE_ENV=development vite build --watch",
    "package:release": "node --no-warnings ./scripts/package_release.mjs",
    "check:release": "node --no-warnings ./scripts/check_release_zip.mjs",
    "make-link": "node --no-warnings ./scripts/make_dev_link.js",
    "deploy:siyuan": "node --no-warnings ./scripts/deploy_siyuan.mjs",
    "check:siyuan": "node --no-warnings ./scripts/check_siyuan_integration.mjs",
    "check:data": "node --no-warnings ./scripts/check_data_compat.mjs",
    "check:runtime": "node --no-warnings ./scripts/check_runtime.mjs",
    "check:ui-visual": "node --no-warnings ./scripts/check_ui_visual.mjs",
    "check:bundle": "node --no-warnings ./scripts/check_bundle_integrity.mjs",
    "check:repo": "node --no-warnings ./scripts/check_repository_ready.mjs",
    "check:ai-live": "node --no-warnings ./scripts/check_ai_live.mjs",
    "check:e2e-live": "node --no-warnings ./scripts/check_e2e_live.mjs",
    "check:live": "node --no-warnings ./scripts/check_live.mjs",
    "check:all": "npm run check:siyuan && npm run check:data",
    "check:full": "node --no-warnings ./scripts/check_full.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run build",
    "test": "npm run test:json && npm run test:prompt-contracts && npm run test:notebook-client && npm run test:sources && npm run test:local-files && npm run test:source-hub && npm run test:source-refs && npm run test:notebook-bridge && npm run test:ui-contracts && npm run test:render && npm run test:paths && npm run test:providers && npm run test:srs && npm run test:siyuan-riff && npm run test:riff-sync && npm run test:exporters && npm run test:importers && npm run test:mindmap-cards && npm run test:paradigm && npm run test:selection && npm run test:pipeline && npm run test:concept-store && npm run test:graph && npm run test:concept-mindmap && npm run test:card-id && npm run test:symbol-cards && npm run test:unstructured && npm run test:source-store && npm run test:parsers && npm run test:source-ref-migration",
    "test:json": "node --no-warnings ./scripts/test_json_repair.mjs",
    "test:prompt-contracts": "node --no-warnings ./scripts/test_prompt_contracts.mjs",
    "test:pipeline": "node --no-warnings ./scripts/test_pipeline.mjs",
    "test:selection": "node --no-warnings ./scripts/test_selection.mjs",
    "test:concept-store": "node --no-warnings ./scripts/test_concept_store.mjs",
    "test:local-files": "node --no-warnings ./scripts/test_local_file_adapters.mjs",
    "test:source-hub": "node --no-warnings ./scripts/test_source_hub.mjs",
    "test:graph": "node --no-warnings ./scripts/test_concept_graph.mjs",
    "test:concept-mindmap": "node --no-warnings ./scripts/test_concept_mindmap.mjs",
    "test:card-id": "node --no-warnings ./scripts/test_card_id.mjs",
    "test:source-refs": "node --no-warnings ./scripts/test_source_refs.mjs",
    "test:ui-contracts": "node --no-warnings ./scripts/test_ui_contracts.mjs",
    "test:render": "node --no-warnings ./scripts/test_render_math.mjs",
    "test:paths": "node --no-warnings ./scripts/test_siyuan_paths.mjs",
    "test:providers": "node --no-warnings ./scripts/test_llm_providers.mjs",
    "test:srs": "node --no-warnings ./scripts/test_srs_scheduler.mjs",
    "test:symbol-cards": "node --no-warnings ./scripts/test_symbol_cards.mjs",
    "test:unstructured": "node --no-warnings ./scripts/test_unstructured_partitioner.mjs",
    "test:source-store": "node --no-warnings ./scripts/test_source_store.mjs",
    "test:parsers": "node --no-warnings ./scripts/test_parsers.mjs",
    "test:source-ref-migration": "node --no-warnings ./scripts/test_source_ref_migration.mjs",
    "test:siyuan-riff": "node --no-warnings ./scripts/test_siyuan_riff.mjs",
    "test:riff-sync": "node --no-warnings ./scripts/test_riff_sync.mjs",
    "test:exporters": "node --no-warnings ./scripts/test_exporters.mjs",
    "test:importers": "node --no-warnings ./scripts/test_importers.mjs",
    "test:mindmap-cards": "node --no-warnings ./scripts/test_mindmap_cards.mjs",
    "test:paradigm": "node --no-warnings ./scripts/test_concept_card_mindmap_paradigm.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@tsconfig/svelte": "^4.0.1",
    "@types/node": "^20.3.0",
    "cross-env": "^7.0.3",
    "sass": "^1.101.0",
    "siyuan": "1.1.2",
    "svelte": "^4.2.20",
    "typescript": "^5.1.3",
    "vite": "^5.2.9",
    "vite-plugin-static-copy": "^1.0.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "d3": "^7.9.0",
    "fflate": "^0.8.3",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "pdfjs-dist": "^3.11.174",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "ts-fsrs": "^5.4.1",
    "xlsx": "^0.18.5"
  }
}
